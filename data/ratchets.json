[
  {"id": "0-60", "name": "0-60", "type": "simple", "sides": 0, "height": 60, "note": "圓形無齒設計，重心最集中，滑動摩擦力最低，常用於高速旋轉配置。"},
  {"id": "0-70", "name": "0-70", "type": "simple", "sides": 0, "height": 70, "note": "圓形無齒、中高身高，兼顧速度與些微防禦面積。"},
  {"id": "0-80", "name": "0-80", "type": "simple", "sides": 0, "height": 80, "note": "圓形無齒、高身高版本，提升防禦與耐久打擊的穩定度。"},
  {"id": "1-50", "name": "1-50", "type": "standard", "sides": 1, "height": 50, "note": "低身高＋單凸點，重心低、攻擊時貼地感強，是熱門進攻軸心之一。"},
  {"id": "1-60", "name": "1-60", "type": "standard", "sides": 1, "height": 60, "note": "賽場最常見的軸心之一，單凸點設計搭配標準身高，穩定度與速度兼具。"},
  {"id": "1-70", "name": "1-70", "type": "standard", "sides": 1, "height": 70, "note": "單凸點、偏高身高，適合搭配需要離地間隙的 Bit。"},
  {"id": "1-80", "name": "1-80", "type": "standard", "sides": 1, "height": 80, "note": "單凸點最高版本，防禦與耐打表現最突出。"},
  {"id": "2-60", "name": "2-60", "type": "standard", "sides": 2, "height": 60, "note": "雙凸點設計，攻擊接觸面稍增，中等身高。"},
  {"id": "2-70", "name": "2-70", "type": "standard", "sides": 2, "height": 70, "note": "雙凸點、偏高身高的平衡型軸心。"},
  {"id": "2-80", "name": "2-80", "type": "standard", "sides": 2, "height": 80, "note": "雙凸點最高版本，強化耐久與防禦。"},
  {"id": "3-60", "name": "3-60", "type": "standard", "sides": 3, "height": 60, "note": "三凸點標準身高，攻防均衡，是新手也容易上手的軸心。"},
  {"id": "3-70", "name": "3-70", "type": "standard", "sides": 3, "height": 70, "note": "三凸點偏高版本，接觸面積增加、旋轉軌跡更穩。"},
  {"id": "3-80", "name": "3-80", "type": "standard", "sides": 3, "height": 80, "note": "三凸點高身高，適合搭配防禦或耐久型刀刃。"},
  {"id": "3-85", "name": "3-85", "type": "standard", "sides": 3, "height": 85, "note": "三凸點特高身高版本，離地間隙大，可閃避部分低位攻擊。"},
  {"id": "4-50", "name": "4-50", "type": "standard", "sides": 4, "height": 50, "note": "四凸點低身高，重心非常低，適合貼地進攻風格。"},
  {"id": "4-55", "name": "4-55", "type": "simple", "sides": 4, "height": 55, "note": "簡易型（尾數 5）軸心，用扣合式接口直接卡入刀刃，拆裝更快。"},
  {"id": "4-60", "name": "4-60", "type": "standard", "sides": 4, "height": 60, "note": "四凸點標準身高，接觸面較大、耐打性佳。"},
  {"id": "4-70", "name": "4-70", "type": "standard", "sides": 4, "height": 70, "note": "四凸點偏高版本，防禦與續轉力表現不錯。"},
  {"id": "4-80", "name": "4-80", "type": "standard", "sides": 4, "height": 80, "note": "四凸點最高版本，主打長時間續轉與抗打擊。"},
  {"id": "5-60", "name": "5-60", "type": "standard", "sides": 5, "height": 60, "note": "五凸點標準身高，接觸面更廣、旋轉手感偏穩重。"},
  {"id": "5-70", "name": "5-70", "type": "standard", "sides": 5, "height": 70, "note": "五凸點偏高版本，適合防禦體系配置。"},
  {"id": "5-80", "name": "5-80", "type": "standard", "sides": 5, "height": 80, "note": "五凸點最高版本，強調長期耐久對戰。"},
  {"id": "6-60", "name": "6-60", "type": "standard", "sides": 6, "height": 60, "note": "六凸點標準身高，圓周接觸點多、旋轉較平穩。"},
  {"id": "6-80", "name": "6-80", "type": "standard", "sides": 6, "height": 80, "note": "六凸點高身高版本，主打防禦與抗攻擊角度。"},
  {"id": "7-55", "name": "7-55", "type": "simple", "sides": 7, "height": 55, "note": "簡易型七凸點軸心，扣合快速，適合連續對戰時快速換裝。"},
  {"id": "7-60", "name": "7-60", "type": "standard", "sides": 7, "height": 60, "note": "七凸點標準身高，賽場熱門軸心之一，攻防手感均衡。"},
  {"id": "7-70", "name": "7-70", "type": "standard", "sides": 7, "height": 70, "note": "七凸點偏高版本，離地間隙略增，減少部分擦地攻擊。"},
  {"id": "7-80", "name": "7-80", "type": "standard", "sides": 7, "height": 80, "note": "七凸點最高版本，防禦與耐久兼顧。"},
  {"id": "8-70", "name": "8-70", "type": "standard", "sides": 8, "height": 70, "note": "八凸點偏高身高，接觸點多、旋轉軌跡更圓滑。"},
  {"id": "9-60", "name": "9-60", "type": "standard", "sides": 9, "height": 60, "note": "賽場人氣最高的軸心之一，九凸點提供大量接觸面，攻擊與續轉都出色。"},
  {"id": "9-65", "name": "9-65", "type": "simple", "sides": 9, "height": 65, "note": "簡易型九凸點軸心，快拆設計，身高介於 60 與 70 之間。"},
  {"id": "9-70", "name": "9-70", "type": "standard", "sides": 9, "height": 70, "note": "九凸點偏高版本，防禦與續轉力表現亮眼。"},
  {"id": "9-80", "name": "9-80", "type": "standard", "sides": 9, "height": 80, "note": "九凸點最高版本，主打長期耐久防禦戰。"},
  {"id": "M-85", "name": "M-85", "type": "special", "sides": 0, "height": 85, "note": "特殊字母編號、超高身高軸心，用於特定套裝，離地間隙極大。"}
